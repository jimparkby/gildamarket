generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  telegramUserId  String    @unique @map("telegram_user_id")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  telegramUsername String?  @map("telegram_username")
  avatar          String?
  backgroundImage String?   @map("background_image")
  about           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  items           Item[]
  likedItems      ItemLike[]
  likedShops      ShopLike[]  @relation("UserLikesShop")
  shopLikedBy     ShopLike[]  @relation("ShopLikedByUser")
  lookBoards      LookBoard[]

  @@map("users")
}

model Item {
  id          Int       @id @default(autoincrement())
  title       String
  brand       String?
  category    String
  size        String?
  condition   String    // new, like_new, good, fair
  price       Decimal   @db.Decimal(10, 2)
  currency    String    @default("RUB")
  description String?
  images      String[]  // array of file paths
  isSold      Boolean   @default(false) @map("is_sold")
  status      String    @default("pending") // pending | approved | rejected
  createdAt   DateTime  @default(now()) @map("created_at")

  sellerId    Int       @map("seller_id")
  seller      User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  likes       ItemLike[]

  @@map("items")
}

model BannedTelegramUser {
  telegramUserId String   @id @map("telegram_user_id")
  bannedAt       DateTime @default(now()) @map("banned_at")

  @@map("banned_telegram_users")
}

model ItemLike {
  userId  Int  @map("user_id")
  itemId  Int  @map("item_id")
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item    Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@map("item_likes")
}

model ShopLike {
  userId  Int  @map("user_id")
  shopId  Int  @map("shop_id")
  user    User @relation("UserLikesShop", fields: [userId], references: [id], onDelete: Cascade)
  shop    User @relation("ShopLikedByUser", fields: [shopId], references: [id], onDelete: Cascade)

  @@id([userId, shopId])
  @@map("shop_likes")
}

model LookBoard {
  id          Int      @id @default(autoincrement())
  title       String?
  description String?
  images      String[] // array of file paths
  createdAt   DateTime @default(now()) @map("created_at")

  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("look_boards")
}
