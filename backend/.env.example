# === DATABASE ===
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gilda_db"

# === TELEGRAM ===
BOT_TOKEN=8563872990:AAG8XpJ73M5G5zIV_ettaIiYpNIbWGMZnPA
MINI_APP_URL=https://your-frontend.timeweb.cloud

# === ADMIN PANEL ===
# ID чата/группы для модерации товаров (бот должен быть участником)
# Для группы ID будет отрицательным, например: -1003104024139
ADMIN_REVIEW_CHAT_ID=-1003104024139

# Включить модерацию (показывать только approved товары в ленте).
# Установи true ПОСЛЕ того как выполнил: npm install && npx prisma db push
MODERATION_ENABLED=false

# === JWT ===
JWT_SECRET=change_this_to_a_long_random_string_32plus_chars

# === SERVER ===
PORT=3000
NODE_ENV=production

# === S3 STORAGE (TimeWeb S3) ===
# Создать бакет: TimeWeb → Хранилище S3 → Создать бакет (сделать публичным)
S3_ENDPOINT=https://s3.timeweb.cloud
S3_REGION=ru-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# === LOCAL FALLBACK (только для dev без S3) ===
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
